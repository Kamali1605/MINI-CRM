{
  "name": "xeno-mini-crm",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/crm\" \"npm run dev --workspace=apps/channel-stub\"",
    "build": "npm run build --workspace=apps/crm && npm run build --workspace=apps/channel-stub",
    "db:migrate": "npm run db:migrate --workspace=apps/crm",
    "db:seed": "npm run db:seed --workspace=apps/crm"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
